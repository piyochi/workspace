#!/bin/bash
# ============================================================================
#  claude-monitor — tmux内専用
#  メイン(フォーカス用大画面) + グリッド(ペイン一覧) を展開する
#
#  ※ tmux の中から実行してください
#
#  使い方:
#    claude-monitor ~/proj-a ~/proj-b ~/proj-c       # 空シェル3つ
#    claude-monitor -c ~/proj-a ~/proj-b              # claude自動起動
#    claude-monitor -g 2x3 -f projects.txt
#    claude-monitor -n 4 -g 2x2                       # カレントdir×4
#    claude-monitor -n 6 -l top -w 40%                # 上メイン40%+下リスト60%
#    claude-monitor -a ~/new-proj                     # 後から追加
#    claude-monitor --no-window --name monitor -f f.txt  # tmuxp連携
#    claude-monitor                                   # 対話的に設定
#
#  レイアウト (-l):
#    left    左メイン + 右リスト (デフォルト)
#    right   右メイン + 左リスト
#    top     上メイン + 下リスト
#    bottom  下メイン + 上リスト
#
#  設定ファイル (projects.txt):
#    # ディレクトリだけ → 空シェル
#    ~/project-alpha
#    # ディレクトリ | コマンド → コマンド自動実行
#    ~/project-beta | claude
#    # ディレクトリ | コマンド | タイトル
#    ~/project-gamma | claude --model sonnet | gamma claude
#    ~/logs | tail -f /var/log/app.log | app log
#
#  操作:
#    Alt + 1~9          prefix不要で即切り替え
#    prefix + F1~F12    10~21番目を切り替え
#    ペインクリック → prefix + Enter でメインに持ってくる
#    prefix + a         新しいペインを追加
# ============================================================================

set -eo pipefail

# =============================================
#  tmux内チェック
# =============================================
if [[ -z "${TMUX:-}" ]]; then
  echo "エラー: tmuxの中から実行してください"
  echo ""
  echo "  tmux を起動してから再度実行:"
  echo "    tmux"
  echo "    $0 $*"
  exit 1
fi

CURRENT_SESSION=$(tmux display-message -p '#{session_name}')
MONITOR_NAME="default"
NO_WINDOW=false
LIST_SIZE="50%"
LAYOUT="left"
GRID=""
MODE="normal"
AUTO_CLAUDE=false

# 各ペインの設定: [dir]と[cmd]と[title]を並列配列で管理
declare -a DIRS=()
declare -a CMDS=()
declare -a TITLES=()

# =============================================
#  環境変数キー生成
# =============================================
env_key() { echo "CM_${MONITOR_NAME}_$1"; }

env_get() {
  tmux show-environment -t "$CURRENT_SESSION" "$(env_key "$1")" 2>/dev/null | cut -d= -f2 || true
}

env_set() {
  tmux set-environment -t "$CURRENT_SESSION" "$(env_key "$1")" "$2"
}

env_unset() {
  tmux set-environment -t "$CURRENT_SESSION" -u "$(env_key "$1")" 2>/dev/null || true
}

# =============================================
#  引数パース
# =============================================
while [[ $# -gt 0 ]]; do
  case "$1" in
    -g|--grid)
      shift; GRID="$1"; shift ;;
    -c|--claude)
      AUTO_CLAUDE=true; shift ;;
    --name)
      shift; MONITOR_NAME="$1"; shift ;;
    --no-window)
      NO_WINDOW=true; shift ;;
    -l|--layout)
      shift
      case "$1" in
        left|right|top|bottom) LAYOUT="$1" ;;
        *) echo "エラー: -l は left, right, top, bottom のいずれか"; exit 1 ;;
      esac
      shift ;;
    -f|--file)
      shift
      [[ ! -f "$1" ]] && { echo "エラー: ファイル '$1' が見つかりません"; exit 1; }
      while IFS= read -r line; do
        [[ -z "$line" || "$line" =~ ^# ]] && continue
        if [[ "$line" == *"|"* ]]; then
          # 最初の | がDIR区切り、最後の | がタイトル区切り、間がコマンド
          dir=$(echo "$line" | cut -d'|' -f1 | xargs)
          # |の数を数える
          pipe_count=$(echo "$line" | tr -cd '|' | wc -c | xargs)
          if [[ $pipe_count -ge 2 ]]; then
            # 最後の|以降がタイトル、最初の|と最後の|の間がコマンド
            title=$(echo "$line" | rev | cut -d'|' -f1 | rev | xargs)
            # 最初と最後の|を除いた中間部分がコマンド
            cmd=$(echo "$line" | cut -d'|' -f2-$pipe_count | xargs)
          else
            # |が1つだけ: DIR | CMD
            cmd=$(echo "$line" | cut -d'|' -f2- | xargs)
            title=""
          fi
          DIRS+=("$(eval echo "$dir")")
          CMDS+=("$cmd")
          TITLES+=("$title")
        else
          DIRS+=("$(eval echo "$(echo "$line" | xargs)")")
          CMDS+=("")
          TITLES+=("")
        fi
      done < "$1"
      shift ;;
    -n|--count)
      shift
      for ((i = 1; i <= $1; i++)); do
        DIRS+=("$(pwd)")
        CMDS+=("")
        TITLES+=("")
      done
      shift ;;
    -d|--destroy)
      MODE="destroy"; shift ;;
    -a|--add)
      MODE="add"; shift
      if [[ $# -gt 0 && ! "$1" =~ ^- ]]; then DIRS+=("$1"); shift
      else DIRS+=("$(pwd)"); fi
      CMDS+=("")
      TITLES+=("")
      ;;
    -w|--width)
      shift; LIST_SIZE="$1"; shift ;;
    -h|--help)
      cat << 'EOF'
Usage: claude-monitor [OPTIONS] [DIR1 DIR2 ...]
  ※ tmuxの中から実行してください

起動モード:
  (引数なし)            対話的に設定
  DIR1 DIR2 ...         指定ディレクトリで空シェル起動
  -f, --file FILE       ファイルからディレクトリ&コマンドを読み込み
  -n, --count N         カレントディレクトリでN個起動
  -a, --add [DIR]       既存モニターに新しいペインを追加
  -d, --destroy         モニターウィンドウを破棄

オプション:
  -c, --claude          全ペインで claude を自動起動
  -g, --grid COLSxROWS  グリッドレイアウト (例: 2x3, 3x4)
                        省略時は自動計算
  -l, --layout POSITION メインペインの位置 (デフォルト: left)
                        left:  左メイン + 右リスト
                        right: 右メイン + 左リスト
                        top:   上メイン + 下リスト
                        bottom:下メイン + 上リスト
  -w, --width PERCENT   リスト側のサイズ (デフォルト: 50%)
  --name NAME           モニター名 (複数ウィンドウ共存時に必須)
  --no-window           新しいウィンドウを作らず現在のウィンドウを使う
  -h, --help            このヘルプ

操作キー:
  Alt + 1~9             prefix不要で即切り替え
  prefix + F1~F12       10~21番目を切り替え
  ペインクリック + prefix+Enter  クリックしたペインをメインに
  prefix + a            新しいペインを追加

設定ファイル例 (projects.txt):
  # ディレクトリだけ → 空シェル
  ~/project-alpha

  # ディレクトリ | コマンド → 自動実行
  ~/project-beta | claude

  # ディレクトリ | コマンド | タイトル
  ~/project-gamma | claude --model sonnet | gamma claude
  ~/logs | tail -f /var/log/app.log | app log
EOF
      exit 0 ;;
    *)
      DIRS+=("$1"); CMDS+=(""); TITLES+=(""); shift ;;
  esac
done

# =============================================
#  スクリプトパス (名前空間付き)
# =============================================
DISPATCH_SCRIPT="/tmp/claude-monitor-dispatch.sh"
SWAP_SCRIPT="/tmp/claude-monitor-swap-${MONITOR_NAME}.sh"
ADD_SCRIPT="/tmp/claude-monitor-add-${MONITOR_NAME}.sh"
CLICK_SCRIPT="/tmp/claude-monitor-click-${MONITOR_NAME}.sh"

# =============================================
#  ヘルパー関数
# =============================================
get_monitor_window() {
  env_get WINDOW_ID
}

get_all_pane_ids() {
  local win_id="$1"
  tmux list-panes -t "$win_id" -F '#{pane_id}' | sort
}

get_pane_index() {
  local win_id="$1"
  local pane_id="$2"
  tmux list-panes -t "$win_id" -F '#{pane_id} #{pane_index}' \
    | grep "^${pane_id} " | awk '{print $2}'
}

get_direction_label() {
  case "$LAYOUT" in
    left)   echo "left" ;;
    right)  echo "right" ;;
    top)    echo "top" ;;
    bottom) echo "bottom" ;;
  esac
}

# CM_NAMES にモニター名を追加
register_monitor_name() {
  local names
  names=$(tmux show-environment -t "$CURRENT_SESSION" CM_NAMES 2>/dev/null | cut -d= -f2 || true)
  if [[ -z "$names" ]]; then
    tmux set-environment -t "$CURRENT_SESSION" CM_NAMES "$MONITOR_NAME"
  elif [[ ! ",$names," == *",$MONITOR_NAME,"* ]]; then
    tmux set-environment -t "$CURRENT_SESSION" CM_NAMES "${names},${MONITOR_NAME}"
  fi
}

# CM_NAMES からモニター名を除去
unregister_monitor_name() {
  local names
  names=$(tmux show-environment -t "$CURRENT_SESSION" CM_NAMES 2>/dev/null | cut -d= -f2 || true)
  if [[ -n "$names" ]]; then
    local new_names
    new_names=$(echo "$names" | tr ',' '\n' | grep -v "^${MONITOR_NAME}$" | tr '\n' ',' | sed 's/,$//' || true)
    if [[ -n "$new_names" ]]; then
      tmux set-environment -t "$CURRENT_SESSION" CM_NAMES "$new_names"
    else
      tmux set-environment -t "$CURRENT_SESSION" -u CM_NAMES 2>/dev/null || true
    fi
  fi
}

# =============================================
#  破棄モード (-d)
# =============================================
if [[ "$MODE" == "destroy" ]]; then
  WIN_ID=$(get_monitor_window)
  if [[ -z "$WIN_ID" ]]; then
    echo "モニター '${MONITOR_NAME}' は存在しません。"
    exit 0
  fi
  # --no-window で作られたものはウィンドウを閉じない
  NO_WIN_FLAG=$(env_get NO_WINDOW)
  if [[ "$NO_WIN_FLAG" != "true" ]]; then
    tmux kill-window -t "$WIN_ID" 2>/dev/null
  fi
  # 環境変数をクリア
  CLI_COUNT=$(env_get CLI_COUNT)
  for key in WINDOW_ID LAYOUT FOCUS_IDX CLI_COUNT FOCUSED_CLI NO_WINDOW; do
    env_unset "$key"
  done
  if [[ -n "$CLI_COUNT" ]]; then
    for ((i = 1; i <= CLI_COUNT; i++)); do
      env_unset "CLI_${i}_IDX"
      env_unset "CLI_${i}_TITLE"
    done
  fi
  unregister_monitor_name
  rm -f "$SWAP_SCRIPT" "$ADD_SCRIPT" "$CLICK_SCRIPT"
  # ディスパッチャーは他のmonitorが残っていれば残す
  remaining_names=$(tmux show-environment -t "$CURRENT_SESSION" CM_NAMES 2>/dev/null | cut -d= -f2 || true)
  if [[ -z "$remaining_names" ]]; then
    rm -f "$DISPATCH_SCRIPT"
  fi
  echo "✅ モニター '${MONITOR_NAME}' を破棄しました"
  exit 0
fi

# =============================================
#  追加モード (-a)
# =============================================
if [[ "$MODE" == "add" ]]; then
  WIN_ID=$(get_monitor_window)
  if [[ -z "$WIN_ID" ]]; then
    echo "エラー: モニター '${MONITOR_NAME}' が見つかりません。先に起動してください。"
    exit 1
  fi

  dir="${DIRS[0]}"
  LAYOUT=$(env_get LAYOUT)
  [[ -z "$LAYOUT" ]] && LAYOUT="left"

  CLI_COUNT=$(env_get CLI_COUNT)
  [[ -z "$CLI_COUNT" ]] && CLI_COUNT=0
  NEW_NUM=$((CLI_COUNT + 1))

  LAST_IDX=$(env_get "CLI_${CLI_COUNT}_IDX")
  [[ -z "$LAST_IDX" ]] && LAST_IDX=1

  before=$(get_all_pane_ids "$WIN_ID")
  tmux split-window -t "${WIN_ID}.${LAST_IDX}" -v -c "$dir"
  after=$(get_all_pane_ids "$WIN_ID")
  new_id=$(comm -13 <(echo "$before") <(echo "$after") | head -1)
  new_idx=$(get_pane_index "$WIN_ID" "$new_id")

  env_set "CLI_${NEW_NUM}_IDX" "$new_idx"
  env_set CLI_COUNT "$NEW_NUM"
  tmux set-option -t "$new_id" -p @cm_title "[$NEW_NUM] $(basename "$dir")"

  echo "✅ [$NEW_NUM] を追加しました ($dir) — 空シェル"
  exit 0
fi

# =============================================
#  対話モード (引数なし)
# =============================================
if [[ ${#DIRS[@]} -eq 0 ]]; then
  echo "=== Claude Monitor セットアップ ==="
  echo ""
  read -rp "いくつペインを作りますか？ [3]: " count
  count=${count:-3}
  for ((i = 1; i <= count; i++)); do
    read -rp "[$i] ディレクトリ [$PWD]: " dir
    dir=${dir:-$PWD}; dir="${dir/#\~/$HOME}"
    DIRS+=("$dir")

    read -rp "[$i] 起動コマンド (空Enter=シェルのみ): " cmd
    CMDS+=("$cmd")
    TITLES+=("")
  done
  echo ""
fi

NUM=${#DIRS[@]}
[[ $NUM -lt 1 ]] && { echo "エラー: 最低1つのペインが必要です"; exit 1; }

# -c フラグ: コマンド未指定のペインにclaude を設定
if [[ "$AUTO_CLAUDE" == true ]]; then
  for ((i = 0; i < NUM; i++)); do
    [[ -z "${CMDS[$i]}" ]] && CMDS[$i]="claude"
  done
fi

if [[ $NUM -gt 9 ]]; then
  echo "⚠ 10個以上: prefix+F1~F12 / マウス+prefix+Enter で操作。"
fi

# =============================================
#  グリッド計算
# =============================================
if [[ -n "$GRID" ]]; then
  GRID_COLS=$(echo "$GRID" | cut -dx -f1)
  GRID_ROWS=$(echo "$GRID" | cut -dx -f2)
  GRID_TOTAL=$((GRID_COLS * GRID_ROWS))
  if [[ $NUM -gt $GRID_TOTAL ]]; then
    echo "⚠ CLI数($NUM) > グリッド容量(${GRID}=$GRID_TOTAL) → ${GRID_TOTAL}個まで"
    NUM=$GRID_TOTAL
  fi
else
  if [[ $NUM -le 6 ]]; then
    GRID_COLS=1; GRID_ROWS=$NUM
  elif [[ $NUM -le 12 ]]; then
    GRID_COLS=2; GRID_ROWS=$(( (NUM + 1) / 2 ))
  elif [[ $NUM -le 18 ]]; then
    GRID_COLS=3; GRID_ROWS=$(( (NUM + 2) / 3 ))
  else
    GRID_COLS=4; GRID_ROWS=$(( (NUM + 3) / 4 ))
  fi
  GRID="${GRID_COLS}x${GRID_ROWS}"
fi

# =============================================
#  既存モニター確認
# =============================================
EXISTING_WIN=$(get_monitor_window)
if [[ -n "$EXISTING_WIN" ]]; then
  if tmux list-panes -t "$EXISTING_WIN" &>/dev/null; then
    echo "モニター '${MONITOR_NAME}' は既に存在します。"
    echo "  破棄: $0 -d --name $MONITOR_NAME"
    exit 1
  fi
fi

DIR_LABEL=$(get_direction_label)
echo "🚀 起動: $NUM ペイン (名前: ${MONITOR_NAME}, グリッド: ${GRID}, レイアウト: ${LAYOUT}, リスト: ${LIST_SIZE})"
for i in "${!DIRS[@]}"; do
  cmd="${CMDS[$i]}"
  label="${cmd:-shell}"
  t="${TITLES[$i]}"
  if [[ -n "$t" ]]; then
    echo "  [$((i + 1))] ${t}  (${DIRS[$i]})"
  else
    echo "  [$((i + 1))] ${DIRS[$i]}  →  $label"
  fi
done
echo ""

# =============================================
#  ウィンドウ取得/作成
# =============================================
if [[ "$NO_WINDOW" == true ]]; then
  # TMUX_PANEから自分のペインが所属するウィンドウIDを取得
  # (tmux display-messageはアクティブウィンドウを返すので不正確)
  WIN_ID=$(tmux list-panes -t "${TMUX_PANE}" -F '#{window_id}' | head -1)
else
  tmux new-window -n "$MONITOR_NAME"
  WIN_ID=$(tmux display-message -p '#{window_id}')
fi
env_set WINDOW_ID "$WIN_ID"
env_set LAYOUT "$LAYOUT"
env_set NO_WINDOW "$NO_WINDOW"
register_monitor_name

# =============================================
#  ヘルパースクリプト生成
# =============================================

# ---- ディスパッチャー (全monitor共有、1つだけ) ----
cat > "$DISPATCH_SCRIPT" << 'DISPATCHEOF'
#!/bin/bash
SESSION=$(tmux display-message -p '#{session_name}')
CURRENT_WIN=$(tmux display-message -p '#{window_id}')
TARGET=$1

NAMES=$(tmux show-environment -t "$SESSION" CM_NAMES 2>/dev/null | cut -d= -f2)
[ -z "$NAMES" ] && exit 0

IFS=',' read -ra NAME_ARR <<< "$NAMES"
for name in "${NAME_ARR[@]}"; do
  WIN=$(tmux show-environment -t "$SESSION" "CM_${name}_WINDOW_ID" 2>/dev/null | cut -d= -f2)
  if [ "$WIN" = "$CURRENT_WIN" ]; then
    SWAP="/tmp/claude-monitor-swap-${name}.sh"
    [ -x "$SWAP" ] && exec "$SWAP" "$TARGET"
    exit 0
  fi
done
DISPATCHEOF
chmod +x "$DISPATCH_SCRIPT"

# ---- スワップ (monitor名ごと) ----
cat > "$SWAP_SCRIPT" << SWAPEOF
#!/bin/bash
SESSION="$CURRENT_SESSION"
WIN_ID="$WIN_ID"
NAME="$MONITOR_NAME"
DIR_LABEL="$DIR_LABEL"
TARGET=\$1

[[ -z "\$TARGET" || "\$TARGET" -lt 1 ]] 2>/dev/null && exit 0

TARGET_IDX=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_\${TARGET}_IDX" 2>/dev/null | cut -d= -f2)
[[ -z "\$TARGET_IDX" ]] && exit 0

FOCUS_IDX=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_FOCUS_IDX" 2>/dev/null | cut -d= -f2)
[[ -z "\$FOCUS_IDX" ]] && exit 0

CURRENT=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_FOCUSED_CLI" 2>/dev/null | cut -d= -f2)
[[ -z "\$CURRENT" ]] && CURRENT="none"

# 同じ番号をもう一度 → リストに戻す (トグル)
[[ "\$TARGET" = "\$CURRENT" ]] && {
  CURRENT_IDX=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_\${CURRENT}_IDX" 2>/dev/null | cut -d= -f2)
  CURRENT_TITLE=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_\${CURRENT}_TITLE" 2>/dev/null | cut -d= -f2)
  tmux swap-pane -t "\${WIN_ID}.\${FOCUS_IDX}" -s "\${WIN_ID}.\${CURRENT_IDX}"
  tmux set-option -t "\${WIN_ID}.\${CURRENT_IDX}" -p @cm_title "\${CURRENT_TITLE:-[\$CURRENT]}"
  tmux set-option -t "\${WIN_ID}.\${FOCUS_IDX}" -p @cm_title "★ MAIN"
  tmux set-environment -t "\$SESSION" "CM_\${NAME}_FOCUSED_CLI" "none"
  tmux select-pane -t "\${WIN_ID}.\${FOCUS_IDX}"
  exit 0
}

if [[ "\$CURRENT" != "none" ]]; then
  CURRENT_IDX=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_\${CURRENT}_IDX" 2>/dev/null | cut -d= -f2)
  if [[ -n "\$CURRENT_IDX" ]]; then
    CURRENT_TITLE=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_\${CURRENT}_TITLE" 2>/dev/null | cut -d= -f2)
    tmux swap-pane -t "\${WIN_ID}.\${FOCUS_IDX}" -s "\${WIN_ID}.\${CURRENT_IDX}"
    tmux set-option -t "\${WIN_ID}.\${CURRENT_IDX}" -p @cm_title "\${CURRENT_TITLE:-[\$CURRENT]}"
  fi
fi

TARGET_TITLE=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_\${TARGET}_TITLE" 2>/dev/null | cut -d= -f2)
tmux swap-pane -t "\${WIN_ID}.\${FOCUS_IDX}" -s "\${WIN_ID}.\${TARGET_IDX}"
tmux set-environment -t "\$SESSION" "CM_\${NAME}_FOCUSED_CLI" "\$TARGET"

tmux set-option -t "\${WIN_ID}.\${FOCUS_IDX}" -p @cm_title "★ FOCUS \${TARGET_TITLE:-[\$TARGET]}"
tmux set-option -t "\${WIN_ID}.\${TARGET_IDX}" -p @cm_title "[\$TARGET] → \$DIR_LABEL"
tmux select-pane -t "\${WIN_ID}.\${FOCUS_IDX}"
SWAPEOF
chmod +x "$SWAP_SCRIPT"

# ---- 追加 ----
cat > "$ADD_SCRIPT" << ADDEOF
#!/bin/bash
SESSION="$CURRENT_SESSION"
WIN_ID="$WIN_ID"
NAME="$MONITOR_NAME"
DISPATCH_SCRIPT="$DISPATCH_SCRIPT"
CLI_COUNT=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_COUNT" 2>/dev/null | cut -d= -f2)
[ -z "\$CLI_COUNT" ] && CLI_COUNT=0
NEW_NUM=\$((CLI_COUNT + 1))
LAST_IDX=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_\${CLI_COUNT}_IDX" 2>/dev/null | cut -d= -f2)
[ -z "\$LAST_IDX" ] && LAST_IDX=1

tmux command-prompt -p "ディレクトリ:" "\
  split-window -t \${WIN_ID}.\${LAST_IDX} -v -c '%1' ; \
  run-shell 'sleep 0.3 && \
    NEW_IDX=\\\$(tmux list-panes -t \${WIN_ID} -F \"#{pane_active} #{pane_index}\" | grep ^1 | awk \"{print \\\\\\\$2}\") && \
    tmux set-option -t \${WIN_ID}.\\\$NEW_IDX -p @cm_title \"[\${NEW_NUM}] shell\" && \
    tmux set-environment -t \${SESSION} CM_\${NAME}_CLI_\${NEW_NUM}_IDX \\\$NEW_IDX && \
    tmux set-environment -t \${SESSION} CM_\${NAME}_CLI_\${NEW_NUM}_TITLE \"[\${NEW_NUM}] shell\" && \
    tmux set-environment -t \${SESSION} CM_\${NAME}_CLI_COUNT \${NEW_NUM}'"
ADDEOF
chmod +x "$ADD_SCRIPT"

# ---- クリック→フォーカス ----
cat > "$CLICK_SCRIPT" << CLICKEOF
#!/bin/bash
SESSION="$CURRENT_SESSION"
NAME="$MONITOR_NAME"
SWAP_SCRIPT="$SWAP_SCRIPT"
CLICKED_IDX=\$1
CLI_COUNT=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_COUNT" 2>/dev/null | cut -d= -f2)
[ -z "\$CLI_COUNT" ] && exit 0

for ((n = 1; n <= CLI_COUNT; n++)); do
  idx=\$(tmux show-environment -t "\$SESSION" "CM_\${NAME}_CLI_\${n}_IDX" 2>/dev/null | cut -d= -f2)
  if [ "\$idx" = "\$CLICKED_IDX" ]; then
    exec "\$SWAP_SCRIPT" "\$n"
  fi
done
CLICKEOF
chmod +x "$CLICK_SCRIPT"

# =============================================
#  見た目設定
# =============================================
tmux set-option -t "$CURRENT_SESSION" mouse on
tmux unbind-key -T root MouseDown3Pane
tmux set-option -w -t "$WIN_ID" pane-border-status top
tmux set-option -w -t "$WIN_ID" pane-border-format " #[bold]#{@cm_title} #[default]"

# =============================================
#  レイアウト構築
# =============================================
FOCUS_PANE_ID=$(get_all_pane_ids "$WIN_ID")

# メイン+リスト分割
before=$(get_all_pane_ids "$WIN_ID")
case "$LAYOUT" in
  left)
    tmux split-window -t "${WIN_ID}.0" -h -l "$LIST_SIZE"
    ;;
  right)
    tmux split-window -t "${WIN_ID}.0" -h -b -l "$LIST_SIZE"
    ;;
  top)
    tmux split-window -t "${WIN_ID}.0" -v -l "$LIST_SIZE"
    ;;
  bottom)
    tmux split-window -t "${WIN_ID}.0" -v -b -l "$LIST_SIZE"
    ;;
esac
after=$(get_all_pane_ids "$WIN_ID")
FIRST_LIST_ID=$(comm -13 <(echo "$before") <(echo "$after") | head -1)

# フォーカスペインIDを再取得
all_after=$(get_all_pane_ids "$WIN_ID")
FOCUS_PANE_ID=$(echo "$all_after" | grep -v "^${FIRST_LIST_ID}$" | head -1)

# =============================================
#  グリッド構築
# =============================================
declare -a CLI_IDS=()
declare -a COL_IDS=()

GRID_SPLIT_COL="-h"
GRID_SPLIT_ROW="-v"

COL_IDS=("$FIRST_LIST_ID")

for ((c = 1; c < GRID_COLS; c++)); do
  prev_col="${COL_IDS[$((c - 1))]}"
  remaining=$((GRID_COLS - c))
  pct=$(( remaining * 100 / (remaining + 1) ))
  [[ $pct -lt 10 ]] && pct=50

  before=$(get_all_pane_ids "$WIN_ID")
  tmux split-window -t "$prev_col" $GRID_SPLIT_COL -l "${pct}%"
  after=$(get_all_pane_ids "$WIN_ID")
  new_col=$(comm -13 <(echo "$before") <(echo "$after") | head -1)
  COL_IDS+=("$new_col")
done

# グリッドペインを列優先で作成し、GRID_PANES[col][row]に格納
declare -a GRID_PANES=()
for ((c = 0; c < GRID_COLS; c++)); do
  col_pane="${COL_IDS[$c]}"
  GRID_PANES+=("$col_pane")

  last_in_col="$col_pane"
  for ((r = 1; r < GRID_ROWS; r++)); do
    remaining=$((GRID_ROWS - r))
    pct=$(( remaining * 100 / (remaining + 1) ))
    [[ $pct -lt 10 ]] && pct=50

    before=$(get_all_pane_ids "$WIN_ID")
    tmux split-window -t "$last_in_col" $GRID_SPLIT_ROW -l "${pct}%"
    after=$(get_all_pane_ids "$WIN_ID")
    new_row=$(comm -13 <(echo "$before") <(echo "$after") | head -1)
    GRID_PANES+=("$new_row")
    last_in_col="$new_row"
  done
done

# 行優先に並べ替え: GRID_PANES[col*GRID_ROWS+row] → CLI_IDS[row*GRID_COLS+col]
cli_num=0
for ((r = 0; r < GRID_ROWS; r++)); do
  for ((c = 0; c < GRID_COLS; c++)); do
    cli_num=$((cli_num + 1))
    [[ $cli_num -gt $NUM ]] && break 2
    idx=$((c * GRID_ROWS + r))
    CLI_IDS+=("${GRID_PANES[$idx]}")
  done
done

# =============================================
#  マッピング保存 & ペイン設定
# =============================================
FOCUS_INDEX=$(get_pane_index "$WIN_ID" "$FOCUS_PANE_ID")
env_set FOCUS_IDX "$FOCUS_INDEX"
env_set CLI_COUNT "$NUM"

for ((i = 0; i < ${#CLI_IDS[@]}; i++)); do
  cli_n=$((i + 1))
  pane_id="${CLI_IDS[$i]}"
  pane_idx=$(get_pane_index "$WIN_ID" "$pane_id")
  dir="${DIRS[$i]}"
  cmd="${CMDS[$i]}"
  custom_title="${TITLES[$i]}"
  dirname=$(basename "$dir")

  env_set "CLI_${cli_n}_IDX" "$pane_idx"

  # タイトル: カスタム > コマンド > ディレクトリ名
  if [[ -n "$custom_title" ]]; then
    title="[$cli_n] $custom_title"
  elif [[ -n "$cmd" ]]; then
    title="[$cli_n] $cmd"
  else
    title="[$cli_n] $dirname"
  fi
  env_set "CLI_${cli_n}_TITLE" "$title"
  tmux set-option -t "$pane_id" -p @cm_title "$title"

  # ディレクトリ移動
  tmux send-keys -t "$pane_id" "mkdir -p '$dir' && cd '$dir'" Enter

  # コマンドがあれば実行
  if [[ -n "$cmd" ]]; then
    tmux send-keys -t "$pane_id" "$cmd" Enter
  fi
done

# ---- 初期状態: ペイン1をメインにフォーカス ----
sleep 0.5
first_title=$(env_get CLI_1_TITLE)
CLI1_IDX=$(env_get CLI_1_IDX)
tmux swap-pane -t "${WIN_ID}.${FOCUS_INDEX}" -s "${WIN_ID}.${CLI1_IDX}"
env_set FOCUSED_CLI "1"
tmux set-option -t "${WIN_ID}.${FOCUS_INDEX}" -p @cm_title "★ FOCUS $first_title"
tmux set-option -t "${WIN_ID}.${CLI1_IDX}" -p @cm_title "[1] → $DIR_LABEL"

# =============================================
#  キーバインド (ディスパッチャー経由)
# =============================================
MAX9=$((NUM > 9 ? 9 : NUM))
for ((i = 1; i <= MAX9; i++)); do
  tmux bind-key -T root "M-$i" run-shell "$DISPATCH_SCRIPT $i"
done

if [[ $NUM -gt 9 ]]; then
  MAX_FK=$((NUM > 21 ? 21 : NUM))
  for ((i = 10; i <= MAX_FK; i++)); do
    fkey=$((i - 9))
    tmux bind-key -T prefix "F$fkey" run-shell "$DISPATCH_SCRIPT $i"
  done
fi

tmux bind-key -T prefix Enter run-shell "$CLICK_SCRIPT #{pane_index}"
tmux bind-key -T prefix a run-shell "$ADD_SCRIPT"

# =============================================
#  完了
# =============================================
tmux select-pane -t "${WIN_ID}.${FOCUS_INDEX}"
echo "✅ モニター '${MONITOR_NAME}' を作成しました (${GRID}, ${LAYOUT})"
